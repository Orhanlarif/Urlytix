# Browser-visible API base. Keep the web/API hosts same-site when using the
# API-managed httpOnly access and refresh cookies.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Canonical public site origin (no trailing slash). Used for sitemap, robots,
# Open Graph, and JSON-LD. In production set this to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
