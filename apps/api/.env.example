# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://urlytix:urlytix_password@localhost:5432/urlytix_db
REDIS_URL=redis://localhost:6379

# Auth
# Production startup rejects defaults and secrets shorter than 32 characters.
# Access cookies last 15 minutes; rotating refresh sessions last 30 days.
JWT_SECRET=change_me_to_at_least_32_high_entropy_characters

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public base URL for short links (no trailing slash, no /api/r path)
# Resulting links look like: http://localhost:4000/abc1234
SHORT_URL_BASE=http://localhost:4000

# Frontend origin used in password-reset links (no trailing slash)
APP_WEB_URL=http://localhost:3000

# SMTP — required for real password-reset delivery.
# For Gmail: use an App Password (Google Account → Security → App passwords).
# Example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   SMTP_FROM="Urlytix <you@gmail.com>"
#   SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Urlytix <noreply@example.com>"
SMTP_SECURE=false

# Optional AES key for TOTP secrets; falls back to JWT_SECRET when unset
# TOTP_ENCRYPTION_KEY=

# Optional parent cookie Domain for split web/API hosts (e.g. .example.com).
# Prefer same-host reverse-proxy cookies; leave unset for localhost.
# COOKIE_DOMAIN=

# Observability (optional)
# APP_VERSION= or GIT_SHA= — included in health + structured logs
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.05
# METRICS_TOKEN= — required to expose /api/metrics in production

# Billing is retained for future use but disabled during the free first phase
BILLING_ENABLED=false

# Production also requires DATABASE_URL, REDIS_URL, SHORT_URL_BASE, APP_WEB_URL,
# SMTP_HOST, SMTP_FROM, and at least one HTTPS-only CORS_ORIGINS entry.
# Registration provisions an OWNER workspace.
