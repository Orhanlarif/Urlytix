# Copy to infra/.env on the target host and inject real values from its secret store.
# Never commit infra/.env. Use distinct values and domains for staging and production.
COMPOSE_PROJECT_NAME=urlytix-staging
IMAGE_TAG=replace-with-immutable-commit-sha
API_IMAGE=ghcr.io/replace-owner/urlytix-api
MIGRATION_IMAGE=ghcr.io/replace-owner/urlytix-migrate
WEB_IMAGE=ghcr.io/replace-owner/urlytix-web

POSTGRES_USER=urlytix
POSTGRES_DB=urlytix
POSTGRES_PASSWORD=replace-from-secret-store
REDIS_PASSWORD=replace-from-secret-store
JWT_SECRET=replace-with-at-least-32-random-bytes-from-secret-store

CORS_ORIGINS=https://staging.example.invalid
SHORT_URL_BASE=https://staging-api.example.invalid
APP_WEB_URL=https://staging.example.invalid
NEXT_PUBLIC_API_URL=https://staging-api.example.invalid/api
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# Transactional email (required in production API)
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_USER=replace-from-secret-store
SMTP_PASS=replace-from-secret-store
SMTP_FROM="Urlytix <noreply@staging.example.invalid>"
SMTP_SECURE=false
# Optional; defaults to JWT_SECRET when unset
# TOTP_ENCRYPTION_KEY=replace-with-dedicated-32-plus-char-secret

# Optional split-host cookie Domain (prefer same-host /api routing instead)
# COOKIE_DOMAIN=.example.invalid

# Observability
# APP_VERSION=replace-with-immutable-commit-sha
# SENTRY_DSN=replace-from-secret-store
# METRICS_TOKEN=replace-from-secret-store

# Operator-only inputs for `pnpm release:staging:gate` (do not commit secrets).
STAGING_API_URL=https://staging-api.example.invalid/api
STAGING_CONFIRM=urlytix-staging
# STAGING_SMOKE_EMAIL=release-operator@example.invalid
# STAGING_SMOKE_PASSWORD=replace-from-secret-store
# STAGING_SMOKE_DESTINATION=https://example.com/urlytix-release-smoke
